generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 사용자 & 인증
// ============================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SELLER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  password      String
  name          String
  phone         String?
  role          UserRole     @default(SELLER)
  status        UserStatus   @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  sellerProfile   SellerProfile?
  orders          Order[]
  inquiries       Inquiry[]
  notifications   Notification[]
  activityLogs    ActivityLog[]
  chatMessages    ChatMessage[]
  depositRequests DepositRequest[]

  tenantId    String?
  tenant      Tenant?      @relation("TenantMembers", fields: [tenantId], references: [id])
  ownedTenant Tenant?      @relation("TenantOwner")
  inviteLinks InviteLink[]
  auditLogs   AuditLog[]
}

model SellerProfile {
  id               String      @id @default(cuid())
  userId           String      @unique
  user             User        @relation(fields: [userId], references: [id])
  businessName     String
  businessNumber   String
  bizLicenseUrl    String
  gradeId          String
  grade            SellerGrade @relation(fields: [gradeId], references: [id])
  customFeeRate    Decimal?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model SellerGrade {
  id            String          @id @default(cuid())
  name          String          @unique
  level         Int             @unique
  feeRate       Decimal
  description   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  sellers       SellerProfile[]
  prices        ProductPrice[]

  tenantId      String?
  tenant        Tenant?          @relation(fields: [tenantId], references: [id])
}

// ============================================
// 상품 & 카테고리
// ============================================

enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

enum ProductSource {
  SELF
  SUPPLIER
}

model Category {
  id          String     @id @default(cuid())
  name        String
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  createdAt   DateTime   @default(now())

  products    Product[]

  tenantId    String?
  tenant      Tenant?    @relation(fields: [tenantId], references: [id])
}

model Product {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  description   String?
  basePrice     Decimal
  costPrice     Decimal?
  unit          String        @default("EA")
  stock         Int           @default(0)
  minStock      Int           @default(10)
  shippingFee   Decimal       @default(0)
  status        ProductStatus @default(ACTIVE)
  source        ProductSource
  categoryId    String?
  category      Category?     @relation(fields: [categoryId], references: [id])
  supplierId    String?
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])
  imageUrl      String?
  images        String[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  gradePrices   ProductPrice[]
  sellerPrices  SellerPrice[]
  orderItems    OrderItem[]

  tenantId      String?
  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
}

model ProductPrice {
  id          String      @id @default(cuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  gradeId     String
  grade       SellerGrade @relation(fields: [gradeId], references: [id])
  price       Decimal

  @@unique([productId, gradeId])
}

model SellerPrice {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sellerId    String
  price       Decimal

  @@unique([productId, sellerId])
}

// ============================================
// 공급사
// ============================================

model Supplier {
  id              String          @id @default(cuid())
  name            String
  contactName     String?
  phone           String?
  email           String?
  kakaoId         String?
  address         String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  products        Product[]
  purchaseOrders  PurchaseOrder[]
  excelTemplate   ExcelTemplate?

  tenantId        String?
  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
}

model ExcelTemplate {
  id          String   @id @default(cuid())
  supplierId  String   @unique
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  name        String
  columns     Json
  fileUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// 주문
// ============================================

enum OrderStatus {
  PENDING
  PREPARING
  SHIPPING
  DELIVERED
  CANCELLED
  RETURNED
  EXCHANGED
}

model Order {
  id              String       @id @default(cuid())
  orderNumber     String       @unique
  sellerId        String
  seller          User         @relation(fields: [sellerId], references: [id])
  status          OrderStatus  @default(PENDING)

  recipientName   String
  recipientPhone  String
  recipientAddr   String
  postalCode      String?

  trackingNumber  String?
  courier         String?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  totalAmount      Decimal
  totalShippingFee Decimal      @default(0)
  feeAmount        Decimal?
  settlementAmt    Decimal?

  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  items           OrderItem[]
  claims          Claim[]
  modificationRequests OrderModificationRequest[]

  tenantId        String?
  tenant          Tenant?      @relation(fields: [tenantId], references: [id])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Decimal
  totalPrice  Decimal
  createdAt   DateTime @default(now())
}

// ============================================
// 발주 (공급사)
// ============================================

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  SHIPPED
  RECEIVED
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  poNumber      String              @unique
  supplierId    String
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  status        PurchaseOrderStatus @default(DRAFT)
  totalAmount   Decimal?
  sentAt        DateTime?
  receivedAt    DateTime?
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  items         PurchaseOrderItem[]

  tenantId      String?
  tenant        Tenant?              @relation(fields: [tenantId], references: [id])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  productName     String
  quantity        Int
  unitPrice       Decimal
  trackingNumber  String?
  relatedOrderIds Json?
  createdAt       DateTime      @default(now())
}

// ============================================
// 클레임 (반품/환불/교환)
// ============================================

enum ClaimType {
  RETURN
  REFUND
  EXCHANGE
}

enum ClaimStatus {
  REQUESTED
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

model Claim {
  id              String      @id @default(cuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id])
  type            ClaimType
  status          ClaimStatus @default(REQUESTED)
  reason          String
  amount          Decimal?
  newTrackingNo   String?
  adminNote       String?
  processedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenantId        String?
  tenant          Tenant?     @relation(fields: [tenantId], references: [id])
}

// ============================================
// 정산
// ============================================

enum SettlementStatus {
  PENDING
  CONFIRMED
  PAID
}

model Settlement {
  id            String           @id @default(cuid())
  sellerId      String
  periodStart   DateTime
  periodEnd     DateTime
  totalSales    Decimal
  totalFee      Decimal
  claimDeduct   Decimal          @default(0)
  netAmount     Decimal
  feeRate       Decimal
  status        SettlementStatus @default(PENDING)
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenantId      String?
  tenant        Tenant?          @relation(fields: [tenantId], references: [id])
}

// ============================================
// 예치금
// ============================================

enum DepositTransactionType {
  CHARGE
  DEDUCT
  REFUND
}

model Deposit {
  id           String               @id @default(cuid())
  sellerId     String               @unique
  balance      Decimal              @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  transactions DepositTransaction[]

  tenantId     String?
  tenant       Tenant?              @relation(fields: [tenantId], references: [id])
}

model DepositTransaction {
  id            String                 @id @default(cuid())
  depositId     String
  deposit       Deposit                @relation(fields: [depositId], references: [id])
  type          DepositTransactionType
  amount        Decimal
  balanceAfter  Decimal
  description   String?
  adminId       String?
  createdAt     DateTime               @default(now())

  tenantId      String?
  tenant        Tenant?                @relation(fields: [tenantId], references: [id])
}

enum DepositRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model DepositRequest {
  id             String               @id @default(cuid())
  sellerId       String
  seller         User                 @relation(fields: [sellerId], references: [id])
  amount         Decimal
  depositorName  String
  status         DepositRequestStatus @default(PENDING)
  adminNote      String?
  processedAt    DateTime?
  processedBy    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tenantId       String?
  tenant         Tenant?              @relation(fields: [tenantId], references: [id])
}

// ============================================
// 문의/게시판
// ============================================

enum InquiryStatus {
  OPEN
  ANSWERED
  CLOSED
}

model Inquiry {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  title       String
  content     String
  answer      String?
  status      InquiryStatus @default(OPEN)
  answeredAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenantId    String?
  tenant      Tenant?       @relation(fields: [tenantId], references: [id])
}

// ============================================
// 공지사항
// ============================================

model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  isImportant Boolean  @default(false)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
}

// ============================================
// 알림
// ============================================

enum NotificationType {
  ORDER_NEW
  TRACKING_UPDATED
  PRICE_CHANGED
  STOCK_LOW
  CLAIM_NEW
  SETTLEMENT_READY
  NOTICE
  SYSTEM
  ORDER_MOD_REQUESTED
  ORDER_MOD_RESPONDED
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  type        NotificationType
  title       String
  message     String
  data        Json?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  tenantId    String?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
}

// ============================================
// 주문 수정 요청
// ============================================

enum OrderModificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model OrderModificationRequest {
  id          String                   @id @default(cuid())
  orderId     String
  order       Order                    @relation(fields: [orderId], references: [id])
  sellerId    String
  changes     Json
  reason      String
  status      OrderModificationStatus  @default(PENDING)
  adminNote   String?
  processedBy String?
  processedAt DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  tenantId    String?
  tenant      Tenant?                  @relation(fields: [tenantId], references: [id])
}

// ============================================
// 활동 로그
// ============================================

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  target      String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
}

// ============================================
// AI 채팅
// ============================================

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

model ChatMessage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  role        ChatRole
  content     String
  metadata    Json?
  createdAt   DateTime @default(now())

  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
}

// ============================================
// 멀티테넌시
// ============================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum InviteType {
  LINK
  CODE
}

model Plan {
  id               String         @id @default(cuid())
  name             String         @unique
  displayName      String
  price            Int            @default(0)
  maxSellers       Int            @default(5)
  maxMonthlyOrders Int            @default(100)
  maxProducts      Int            @default(50)
  maxDailyAiChats  Int            @default(5)
  hasExcel         Boolean        @default(false)
  hasFullStats     Boolean        @default(false)
  trialDays        Int            @default(0)
  isActive         Boolean        @default(true)
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenants          Tenant[]
  subscriptions    Subscription[]
}

model Tenant {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  status        TenantStatus @default(ACTIVE)
  ownerId       String       @unique
  owner         User         @relation("TenantOwner", fields: [ownerId], references: [id])
  planId        String
  plan          Plan         @relation(fields: [planId], references: [id])
  trialEndsAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  subscriptions              Subscription[]
  payments                   Payment[]
  inviteLinks                InviteLink[]
  usageTrackers              UsageTracker[]
  auditLogs                  AuditLog[]

  users                      User[]                      @relation("TenantMembers")
  products                   Product[]
  orders                     Order[]
  categories                 Category[]
  sellerGrades               SellerGrade[]
  suppliers                  Supplier[]
  purchaseOrders             PurchaseOrder[]
  claims                     Claim[]
  settlements                Settlement[]
  deposits                   Deposit[]
  depositTransactions        DepositTransaction[]
  depositRequests            DepositRequest[]
  inquiries                  Inquiry[]
  notices                    Notice[]
  notifications              Notification[]
  orderModificationRequests  OrderModificationRequest[]
  activityLogs               ActivityLog[]
  chatMessages               ChatMessage[]
}

model Subscription {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  planId      String
  plan        Plan               @relation(fields: [planId], references: [id])
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  payments    Payment[]
}

model Payment {
  id               String        @id @default(cuid())
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  subscriptionId   String?
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])
  amount           Int
  status           PaymentStatus @default(PENDING)
  tossPaymentKey   String?
  tossOrderId      String?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
}

model InviteLink {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  code        String     @unique
  type        InviteType @default(LINK)
  expiresAt   DateTime?
  maxUses     Int        @default(0)
  currentUses Int        @default(0)
  isActive    Boolean    @default(true)
  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())
}

model UsageTracker {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  month         String
  monthlyOrders Int      @default(0)
  date          String
  dailyAiChats  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, month, date])
}

model AuditLog {
  id             String   @id @default(cuid())
  actorId        String
  actor          User     @relation(fields: [actorId], references: [id])
  targetTenantId String?
  targetTenant   Tenant?  @relation(fields: [targetTenantId], references: [id])
  action         String
  details        Json?
  createdAt      DateTime @default(now())
}
